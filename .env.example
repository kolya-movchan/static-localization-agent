# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3001

# ── Gemini ─────────────────────────────────────────────────────────────────────
# Get yours at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Models used for image editing (primary → fallback on error)
# gemini-2.0-flash-exp supports image output (responseModalities: IMAGE)
# If you have access to preview models (e.g. gemini-3-pro-image-preview), use those instead
GEMINI_PRIMARY_MODEL=gemini-2.0-flash-exp
GEMINI_FALLBACK_MODEL=gemini-1.5-flash
# Model used by the AI agent chat (text only, no image output needed)
GEMINI_AGENT_MODEL=gemini-1.5-flash

# ── Google Drive ────────────────────────────────────────────────────────────────
# Auth mode: "oauth2" (personal Drive, recommended) or "service_account" (Shared Drives / Workspace)
GOOGLE_AUTH_MODE=oauth2

# ── OAuth2 (personal Drive) ─────────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com → APIs & Services → Credentials
# 2. Create an OAuth 2.0 Client ID (Application type: Web application)
# 3. Add redirect URI: http://localhost:3001/api/auth/google/callback
# 4. Enable Google Drive API for your project
# 5. Start the app, open http://localhost:3001 and click "Connect Google Drive"
GOOGLE_OAUTH_CLIENT_ID=id
GOOGLE_OAUTH_CLIENT_SECRET=secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# ── Service account (Shared Drives / Google Workspace only) ────────────────────
# Only needed when GOOGLE_AUTH_MODE=service_account
# Service accounts cannot upload to personal Drive (no storage quota)
# GOOGLE_SERVICE_ACCOUNT_PATH=./service-account.json

# ── Worker ──────────────────────────────────────────────────────────────────────
# How many jobs to run in parallel (1–5 recommended)
WORKER_CONCURRENCY=1
# How often to poll SQLite for pending jobs (ms)
WORKER_POLL_INTERVAL_MS=3000
# Delay between Gemini API calls within a single job (ms)
RATE_LIMIT_MS=5000
# Max retries per Gemini call before switching to fallback model
MAX_RETRIES=2

# ── Database ────────────────────────────────────────────────────────────────────
DB_PATH=./data/jobs.db
